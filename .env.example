# FullADDMAX-mcp — example .env file
#
# Copy this to `.env` (already gitignored) and uncomment + fill in the
# values you need.  Every variable below is read by the server at
# process start.
#
# Precedence for the LLM section:
#   FULLADDMAX_* > OPENAI_* > host-injected (Claude / Cursor / Copilot)
#                 > local (Ollama / vLLM / LM Studio) > built-in default
#
# All FULLADDMAX_LOG_* vars are also accepted as CLI flags
# (`--log-level`, `--log-format`, `--log-file`, etc.).
# CLI flags always win over env vars.

# ---------------------------------------------------------------------------
# 🔍 Logging  (5 dims, all optional — defaults shown)
# ---------------------------------------------------------------------------

# DEBUG / INFO / WARNING / ERROR / CRITICAL
# FULLADDMAX_LOG_LEVEL=INFO

# text (human-readable) | json (one record per line, parseable by jq/ELK/Loki)
# FULLADDMAX_LOG_FORMAT=text

# Path to log file.  Leave blank to write to stderr.
# FULLADDMAX_LOG_FILE=

# Rotate --log-file when it exceeds this many bytes.  0 = no rotation.
# FULLADDMAX_LOG_ROTATE_MAX_BYTES=0

# Number of rotated files to keep (default 3).  e.g. 5 -> .log + .1..5
# FULLADDMAX_LOG_ROTATE_BACKUPS=3

# Language for user-facing error messages.
#   en    -> English (default)
#   zh-CN -> Simplified Chinese (parameter errors, tool errors, rate limits)
# Affects error messages returned to the MCP host's chat transcript.
# Does NOT translate panel labels or log format.
# FULLADDMAX_LANG=en

# ---------------------------------------------------------------------------
# 🤖 LLM credentials  (any one of the 3 blocks below)
# ---------------------------------------------------------------------------

# --- Option 1: explicit FULLADDMAX_* (highest priority) ---
# FULLADDMAX_BASE_URL=https://api.openai.com/v1
# FULLADDMAX_API_KEY=sk-your-key-here
# FULLADDMAX_MODEL=gpt-4o-mini
# FULLADDMAX_TEMPERATURE=0.7
# FULLADDMAX_MAX_TOKENS=2048
# FULLADDMAX_TIMEOUT=60.0
# FULLADDMAX_MAX_RETRIES=2

# --- Option 2: generic OPENAI_* (also picked up) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Option 3: local Ollama (auto-detected when OLLAMA_HOST is set) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b
#   (Ollama ignores api_key but the field is required by our schema;
#    set it to any non-empty value, e.g. "ollama")

# --- Option 4: vLLM / LM Studio (auto-detected) ---
# VLLM_BASE_URL=http://localhost:8000/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
#   (api_key still required, set to "EMPTY" or any value)

# ---------------------------------------------------------------------------
# 🇨🇳 China — pick ONE of the following.  All 6 providers speak the
# OpenAI Chat Completions protocol, so the LLMClient needs no
# special-casing — only the env-var names differ.  Priority is
# env_autodetect()'s natural order: first non-empty value wins.
# Leave all 6 sections below commented and the server still starts
# in off-the-shelf (offline) mode.
# ---------------------------------------------------------------------------

# --- 🇨🇳 Option 5: DeepSeek (深度求索) — https://platform.deepseek.com/ ---
# Fast + cheap + strong reasoning.  Default model: deepseek-chat.
# Set DEEPSEEK_MODEL=deepseek-reasoner to use R1.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# --- 🇨🇳 Option 6: 通义千问 Qwen (DashScope) — https://dashscope.aliyun.com/ ---
# Official env-var prefix is DASHSCOPE_; QWEN_ also accepted.
# Models: qwen-plus / qwen-max / qwen-turbo / qwen-coder-plus / qwen-long.
# DASHSCOPE_API_KEY=sk-...
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# --- 🇨🇳 Option 7: 智谱 GLM (ZhipuAI) — https://open.bigmodel.cn/ ---
# Official env-var prefix is ZHIPUAI_; GLM_ also accepted.
# Models: glm-4-plus / glm-4-flash / glm-4-air / glm-4-airx.
# ZHIPUAI_API_KEY=...
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-plus

# --- 🇨🇳 Option 8: 豆包 Doubao (Volcano Ark / 火山方舟) — https://www.volcengine.com/product/doubao ---
# Official env-var prefix is ARK_; DOUBAO_ also accepted.
# Models: doubao-pro-32k / doubao-lite-32k / doubao-pro-128k.
# ARK_API_KEY=...
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-pro-32k

# --- 🇨🇳 Option 9: Kimi (月之暗面 Moonshot) — https://platform.moonshot.cn/ ---
# Official env-var prefix is MOONSHOT_; KIMI_ also accepted.
# Long-context specialist: moonshot-v1-128k / 32k / 8k.
# MOONSHOT_API_KEY=sk-...
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-128k

# --- 🇨🇳 Option 10: Yi (零一万物 01.AI) — https://platform.lingyiwanwu.com/ ---
# Official env-var prefix is LINGYIWANWU_; YI_ also accepted.
# Models: yi-large / yi-medium / yi-vision / yi-34b-chat.
# YI_API_KEY=...
# YI_BASE_URL=https://api.lingyiwanwu.com/v1
# YI_MODEL=yi-large

# ---------------------------------------------------------------------------
# 🚫 Force offline stub mode  (no LLM, no network)
# ---------------------------------------------------------------------------

# Set to 1 to force all 7 agent ops to return deterministic Markdown
# frameworks instead of calling the LLM.  Useful for tests, demos, and
# environments with no internet.  Server still works for knowledge /
# config / admin.
# FULLADDMAX_AGENT_OFFLINE=0

# ---------------------------------------------------------------------------
# 🏢 MCP host injection  (informational — you usually don't set these)
# ---------------------------------------------------------------------------
# When FullADDMAX-mcp runs inside Claude Desktop / Cursor / Codex / etc.,
# the host injects env vars that we auto-detect.  The actual env-var
# names depend on the host; we look for these prefixes:
#   CLAUDE_ / ANTHROPIC_       -> Claude Desktop, Claude Code, Trae
#   CURSOR_                    -> Cursor
#   CODEX_ / OPENAI_CODEX_     -> Codex CLI
#   CONTINUE_                  -> Continue.dev
#   COPILOT_ / GITHUB_COPILOT_ -> GitHub Copilot
#   CLINE_                     -> Cline
#   AIDER_                     -> Aider
#   ZED_ / ZED_AGENT_          -> Zed
# You generally don't need to set these — the host does it for you.
#
# China-native MCP hosts (Cherry Studio / ChatGPT Box / Dify / NextChat
# / FastGPT) typically do NOT inject env vars.  Set the DEEPSEEK_*
# / QWEN_* / GLM_* / ARK_* / MOONSHOT_* / YI_* vars from the section
# above instead, OR use the FULLADDMAX_* / OPENAI_* universal vars.
